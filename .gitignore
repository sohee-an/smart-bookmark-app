*storybook.log
storybook-static

# Windows Executables (vites.cmd, etc.)
*.exe
*.bat
*.ps1

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# ─── Claude Code ───────────────────────────────────
# 민감 정보 (MCP 토큰, API 키 등)
.claude/settings.json
.claude/settings.local.json

# 로컬 전용 (올릴 필요 없음)
.claude/.session
.claude/todos.md

# 개인용
.agents
portfolio.md
ai-dev-pipeline.md
ai-pipeline 정리와 개선.md

# 올려도 되는 것들 (아래는 gitignore 제외)
# .claude/commands/   ← 커밋, 테스트 등 커맨드
# .claude/agents/     ← ui-agent 등 서브에이전트
# .claude/skills/     ← react-best-practices 등 스킬
# CLAUDE.md           ← 프로젝트 컨텍스트

# ─── Gemini CLI ────────────────────────────────────
# 민감 정보 (OAuth 토큰, API 키 등)
.gemini/settings.json
.gemini/credentials.json 

# 로컬 전용
.gemini/.session
.gemini/history/

# 올려도 되는 것들
# GEMINI.md           ← 프로젝트 컨텍스트
# .gemini/commands/   ← 커맨드

# ─── 공통 AI 도구 ───────────────────────────────────
# MCP 설정 (토큰 포함 가능)
.mcp.json

# 각종 AI 도구 캐시
.aider*
.continue/
.cursor/

