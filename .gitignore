!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# Turborepo
.turbo

# pnpm
.pnpm-store
.pnpm-debug.log*

# misc
.DS_Store
*.pem
.cache

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
