# ─────────────────────────────────────────────────────────────
# E2E 테스트 전용 환경 — 프로덕션/개발 데이터 오염 방지용 격리
#
# ⚠️ 반드시 "별도의 테스트 Supabase 프로젝트" 값을 넣을 것.
#    실 프로젝트 키를 넣으면 E2E가 실제 사용자 데이터를 건드린다.
#
# 사용법:
#   1) Supabase에서 테스트 전용 프로젝트 생성 (또는 supabase branching)
#   2) supabase/migrations/*.sql 를 그 프로젝트에 적용
#   3) 이 파일을 .env.test 로 복사 후 실제 테스트 프로젝트 값 채우기
#   4) pnpm test:e2e (아래 playwright 연동 참고)
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://<TEST-PROJECT-REF>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<test-anon-key>

# 시드/teardown용 (서버 전용, 절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=<test-service-role-key>

# E2E에서는 실제 AI 호출을 피하고 모킹 권장 → 더미로 충분
GEMINI_API_KEY=dummy-for-e2e
